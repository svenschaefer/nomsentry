{
  "name": "nomsentry",
  "version": "1.0.2",
  "description": "Deterministic identifier policy and deception detection engine",
  "type": "module",
  "main": "src/index.js",
  "files": [
    "bin/",
    "src/",
    "dist/",
    "custom/sources/README.md",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "bin": {
    "nomsentry": "bin/nomsentry.js"
  },
  "scripts": {
    "test": "node test/run-tests.js",
    "lint:check": "eslint .",
    "format:check": "prettier --check \"*.{json,md,yml,yaml}\" \"bin/**/*.js\" \"scripts/**/*.js\" \"src/**/*.js\" \"test/**/*.js\" \".github/workflows/**/*.yml\"",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "coverage:check": "c8 --reporter=text-summary --reporter=json-summary node test/run-tests.js && node scripts/check-coverage-thresholds.js",
    "benchmark:runtime": "node scripts/benchmark-runtime.js",
    "benchmark:check": "node scripts/check-runtime-benchmark-budget.js",
    "docs:check": "node scripts/check-docs-consistency.js",
    "freshness:check": "node scripts/check-source-freshness.js",
    "integrity:check": "node scripts/check-source-integrity.js",
    "attestation:check": "node scripts/check-release-attestation.js",
    "determinism:check": "npm run determinism:check:sources && npm run determinism:check:runtime",
    "determinism:check:sources": "node scripts/check-maintained-sources-determinism.js",
    "determinism:check:runtime": "node scripts/check-runtime-bundle-determinism.js",
    "pack:check": "npm pack --dry-run",
    "pack:smoke": "node scripts/check-package-smoke.js",
    "security:check": "node scripts/check-security-baseline.js",
    "release:check": "npm run ci:check && npm run pack:check && npm run pack:smoke",
    "ci:check": "npm run lint:check && npm run format:check && npm run typecheck && npm test && npm run coverage:check && npm run docs:check && npm run build:runtime-sources && npm run determinism:check && npm run freshness:check && npm run integrity:check && npm run attestation:check && npm run security:check && npm run benchmark:check",
    "import:ldnoobw": "node scripts/import-ldnoobw.js",
    "import:2toad": "node scripts/import-2toad-profanity.js",
    "import:obscenity": "node scripts/import-obscenity.js",
    "import:uspto": "node scripts/import-uspto-trademarks.js",
    "derive:uspto-brand-risk": "node scripts/derive-uspto-brand-risk.js",
    "compact:sources": "node scripts/compact-sources.js",
    "build:runtime-sources": "node scripts/build-runtime-sources.js",
    "import:cuss": "node scripts/import-cuss.js",
    "import:dsojevic": "node scripts/import-dsojevic-profanity.js",
    "import:insult-wiki": "node scripts/import-insult-wiki.js",
    "import:gitlab-reserved": "node scripts/import-gitlab-reserved-names.js",
    "import:github-reserved-usernames": "node scripts/import-github-reserved-usernames.js",
    "import:icann-reserved-names": "node scripts/import-icann-reserved-names.js",
    "import:reserved-usernames": "node scripts/import-reserved-usernames.js",
    "import:reserved-usernames-impersonation": "node scripts/import-reserved-usernames-impersonation.js",
    "import:windows-reserved-uri-schemes": "node scripts/import-windows-reserved-uri-schemes.js",
    "derive:impersonation": "node scripts/derive-impersonation.js",
    "derive:composite-risk": "node scripts/derive-composite-risk.js",
    "evaluate:wikidata-brands": "node scripts/evaluate-wikidata-brand-supplement.js",
    "evaluate:brand-profile": "node scripts/evaluate-brand-profile.js",
    "derive:wikidata-brand-risk": "node scripts/derive-wikidata-brand-risk.js",
    "integrity:capture": "node scripts/capture-source-integrity.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@2toad/profanity": "^3.2.0",
    "cuss": "^2.2.0",
    "obscenity": "^0.4.6",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.6.1",
    "c8": "^11.0.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "reserved-usernames": "^1.1.6",
    "typescript": "^5.9.3"
  }
}
