{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["node"],
    "lib": ["ES2023"]
  },
  "include": [
    "src/types.js",
    "src/schema/source-format.js",
    "src/schema/validate-source.js",
    "src/loaders/runtime-bundle.js"
  ]
}
